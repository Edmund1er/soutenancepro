{% extends 'admin_layout.html.twig' %}

{% block title %}Mes soutenances{% endblock %}

{% block body %}
<!-- [ breadcrumb ] start -->
<div class="page-header">
    <div class="page-block">
        <div class="row align-items-center">
            <div class="col-md-12">
                <div class="page-header-title">
                    <h5 class="m-b-10">Mes soutenances</h5>
                </div>
                <ul class="breadcrumb">
                    <li class="breadcrumb-item"><a href="{{ path('enseignant_dashboard') }}"><i class="feather icon-home"></i></a></li>
                    <li class="breadcrumb-item"><a href="#!">Mes soutenances</a></li>
                </ul>
            </div>
        </div>
    </div>
</div>
<!-- [ breadcrumb ] end -->

<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header">
                <h5>Liste de mes soutenances</h5>
                <div class="card-header-right">
                    <div class="btn-group card-option">
                        <button type="button" class="btn dropdown-toggle" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                            <i class="feather icon-more-horizontal"></i>
                        </button>
                        <ul class="list-unstyled card-option dropdown-menu dropdown-menu-right">
                            <li class="dropdown-item full-card"><a href="#!"><span><i class="feather icon-maximize"></i> maximize</span><span style="display:none"><i class="feather icon-minimize"></i> Restore</span></a></li>
                            <li class="dropdown-item minimize-card"><a href="#!"><span><i class="feather icon-minus"></i> collapse</span><span style="display:none"><i class="feather icon-plus"></i> expand</span></a></li>
                            <li class="dropdown-item reload-card"><a href="#!"><i class="feather icon-refresh-cw"></i> reload</a></li>
                            <li class="dropdown-item close-card"><a href="#!"><i class="feather icon-trash"></i> remove</a></li>
                        </ul>
                    </div>
                </div>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover table-bordered">
                        <thead class="thead-light">
                            <tr>
                                <th>ETUDIANT</th>
                                <th>FILIERE</th>
                                <th>THEME</th>
                                <th>DATE</th>
                                <th>HEURE</th>
                                <th>SALLE</th>
                                <th>MON ROLE</th>
                            </tr>
                        </thead>
                        <tbody>
                        {% for soutenance in soutenances %}
                            <tr>
                                <td><strong>{{ soutenance.etudiant.nom }} {{ soutenance.etudiant.prenom }}</strong></small></td>
                                <td>{{ soutenance.etudiant.filiere }}</small></td>
                                <td>{{ soutenance.etudiant.themeMemoire|slice(0, 60) }}{% if soutenance.etudiant.themeMemoire|length > 60 %}...{% endif %}</small></td>
                                <td>{{ soutenance.date|date('d/m/Y') }}</small></td>
                                <td>{{ soutenance.heure|date('H:i') }}</small></td>
                                <td>{{ soutenance.salle.code }}<br><small class="text-muted">{{ soutenance.salle.localisation }}</small></small></td>
                                <td>
                                    {% if soutenance.president and soutenance.president.id == app.user.id %}
                                        <span class="badge badge-danger">President</span>
                                    {% endif %}
                                    {% if soutenance.rapporteur and soutenance.rapporteur.id == app.user.id %}
                                        <span class="badge badge-warning">Rapporteur</span>
                                    {% endif %}
                                    {% if soutenance.examinateur and soutenance.examinateur.id == app.user.id %}
                                        <span class="badge badge-info">Examinateur</span>
                                    {% endif %}
                                </small></td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="7" class="text-center text-muted py-4">
                                    Aucune soutenance pour le moment
                                </small></td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>

                <!-- PAGINATION (5 lignes max) -->
                {% if totalPages > 1 %}
                <div class="row mt-3">
                    <div class="col-sm-12">
                        <nav aria-label="Page navigation">
                            <ul class="pagination justify-content-center">
                                {% if page > 1 %}
                                    <li class="page-item"><a class="page-link" href="{{ path('enseignant_mes_soutenances', {page: page-1}) }}">Precedent</a></li>
                                {% else %}
                                    <li class="page-item disabled"><span class="page-link">Precedent</span></li>
                                {% endif %}

                                {% for p in 1..totalPages %}
                                    <li class="page-item {{ p == page ? 'active' : '' }}">
                                        <a class="page-link" href="{{ path('enseignant_mes_soutenances', {page: p}) }}">{{ p }}</a>
                                    </li>
                                {% endfor %}

                                {% if page < totalPages %}
                                    <li class="page-item"><a class="page-link" href="{{ path('enseignant_mes_soutenances', {page: page+1}) }}">Suivant</a></li>
                                {% else %}
                                    <li class="page-item disabled"><span class="page-link">Suivant</span></li>
                                {% endif %}
                            </ul>
                        </nav>
                    </div>
                </div>
                {% endif %}
            </div>
            <div class="card-footer text-right">
                <a href="{{ path('enseignant_dashboard') }}" class="text-primary">
                    <i class="feather icon-arrow-left"></i> Retour au dashboard
                </a>
            </div>
        </div>
    </div>
</div>
{% endblock %}