{% extends 'base.html.twig' %}

{% block title %}SoutenancePro - Gestion des soutenances{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    /* Hero Section Améliorée */
    .hero-section {
        position: relative;
        background: linear-gradient(135deg, #4680ff 0%, #1a4fc3 50%, #0a2b6e 100%);
        color: white;
        padding: 80px 0 100px;
        margin-top: -20px;
        overflow: hidden;
    }
    
    .hero-section::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: url('{{ asset('assets/images/hero-bg.jpg') }}') center/cover no-repeat;
        opacity: 0.15;
        z-index: 0;
    }
    
    .hero-section .container {
        position: relative;
        z-index: 2;
    }
    
    .hero-title {
        font-size: 3.5rem;
        font-weight: 800;
        margin-bottom: 20px;
        text-shadow: 2px 2px 4px rgba(0,0,0,0.1);
    }
    
    .hero-subtitle {
        font-size: 1.2rem;
        opacity: 0.95;
        margin-bottom: 35px;
        line-height: 1.6;
    }
    
    .hero-illustration {
        max-height: 320px;
        filter: drop-shadow(0 10px 20px rgba(0,0,0,0.2));
        animation: float 3s ease-in-out infinite;
    }
    
    @keyframes float {
        0%, 100% { transform: translateY(0px); }
        50% { transform: translateY(-15px); }
    }
    
    .btn-login {
        background: white;
        color: #4680ff;
        border: none;
        padding: 12px 35px;
        border-radius: 40px;
        font-weight: 700;
        transition: all 0.3s ease;
        margin-right: 15px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    }
    
    .btn-login:hover {
        transform: scale(1.05);
        box-shadow: 0 8px 25px rgba(0,0,0,0.15);
        background: white;
        color: #1a4fc3;
    }
    
    .btn-outline-custom {
        background: transparent;
        border: 2px solid white;
        color: white;
        padding: 10px 33px;
        border-radius: 40px;
        font-weight: 600;
        transition: all 0.3s ease;
    }
    
    .btn-outline-custom:hover {
        background: white;
        color: #4680ff;
        transform: scale(1.05);
    }
    
    .btn-dashboard {
        background: #28a745;
        color: white;
        border: none;
        padding: 12px 35px;
        border-radius: 40px;
        font-weight: 700;
        transition: all 0.3s ease;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    }
    
    .btn-dashboard:hover {
        background: #218838;
        transform: scale(1.05);
    }
    
    /* Cartes statistiques */
    .stat-box {
        background: white;
        border-radius: 15px;
        padding: 25px 20px;
        text-align: center;
        box-shadow: 0 10px 30px rgba(0,0,0,0.08);
        transition: all 0.3s ease;
        border-bottom: 4px solid #4680ff;
    }
    
    .stat-box:hover {
        transform: translateY(-8px);
        box-shadow: 0 20px 40px rgba(0,0,0,0.12);
    }
    
    .stat-number {
        font-size: 2.5rem;
        font-weight: 800;
        color: #4680ff;
    }
    
    .stat-label {
        font-size: 0.9rem;
        color: #666;
        margin-top: 10px;
        font-weight: 500;
    }
    
    /* Feature Cards */
    .feature-card {
        border: none;
        border-radius: 15px;
        transition: all 0.3s ease;
        box-shadow: 0 10px 25px rgba(0,0,0,0.08);
        height: 100%;
        overflow: hidden;
    }
    
    .feature-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 20px 40px rgba(0,0,0,0.12);
    }
    
    .feature-img {
        height: 180px;
        object-fit: cover;
        width: 100%;
    }
    
    .feature-icon {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: -30px auto 15px;
        position: relative;
        z-index: 10;
        font-size: 24px;
        color: white;
        box-shadow: 0 5px 15px rgba(0,0,0,0.2);
    }
    
    .icon-primary { background: #4680ff; }
    .icon-success { background: #9ccc65; }
    .icon-warning { background: #ffba57; }
    .icon-danger { background: #ff5252; }
    
    .section-title {
        font-size: 2rem;
        font-weight: 700;
        margin-bottom: 40px;
        text-align: center;
        position: relative;
        color: #2c3e50;
    }
    
    .section-title:after {
        content: '';
        display: block;
        width: 60px;
        height: 4px;
        background: #4680ff;
        margin: 15px auto 0;
        border-radius: 2px;
    }
    
    .about-section {
        background: #f8f9fa;
        padding: 60px 0;
        border-radius: 30px;
        margin: 50px 0;
    }
    
    .about-img {
        border-radius: 20px;
        box-shadow: 0 20px 40px rgba(0,0,0,0.1);
        width: 100%;
        max-height: 350px;
        object-fit: cover;
    }
    
    .testimonial-card {
        background: #fff;
        border-radius: 15px;
        padding: 25px;
        text-align: center;
        box-shadow: 0 10px 25px rgba(0,0,0,0.08);
        height: 100%;
        transition: all 0.3s ease;
    }
    
    .testimonial-card:hover {
        transform: translateY(-5px);
    }
    
    .testimonial-img {
        width: 70px;
        height: 70px;
        border-radius: 50%;
        object-fit: cover;
        margin: -45px auto 15px;
        border: 3px solid #4680ff;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    }
    
    .cta-section {
        background: linear-gradient(135deg, #4680ff 0%, #0a2b6e 100%);
        padding: 60px;
        border-radius: 20px;
        color: white;
        text-align: center;
        margin: 50px 0;
    }
    
    .cta-section .btn-light {
        padding: 12px 40px;
        border-radius: 40px;
        font-weight: 700;
    }
    
    footer {
        background: #1a252f;
        color: white;
        padding: 50px 0 20px;
        margin-top: 60px;
    }
    
    footer a {
        color: #aaa;
        text-decoration: none;
        transition: all 0.3s ease;
    }
    
    footer a:hover {
        color: #4680ff;
        padding-left: 5px;
    }
    
    .social-icons a {
        display: inline-block;
        width: 35px;
        height: 35px;
        background: rgba(255,255,255,0.1);
        border-radius: 50%;
        text-align: center;
        line-height: 35px;
        margin-right: 10px;
        transition: all 0.3s ease;
    }
    
    .social-icons a:hover {
        background: #4680ff;
        transform: translateY(-3px);
    }
    
    /* Badge stats */
    .stat-badge {
        display: inline-block;
        background: rgba(70,128,255,0.1);
        padding: 5px 15px;
        border-radius: 20px;
        font-size: 0.8rem;
        font-weight: 600;
        margin-top: 10px;
    }
    
    @media (max-width: 768px) {
        .hero-title { font-size: 2rem; }
        .hero-subtitle { font-size: 1rem; }
        .hero-section { padding: 50px 0 60px; }
        .btn-login, .btn-outline-custom { padding: 8px 20px; margin: 5px; }
        .section-title { font-size: 1.5rem; }
        .cta-section { padding: 30px 20px; }
        .cta-section h3 { font-size: 1.3rem; }
    }
</style>
{% endblock %}

{% block body %}
<!-- Hero Section Améliorée -->
<section class="hero-section">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-7">
                <h1 class="hero-title">SoutenancePro</h1>
                <p class="hero-subtitle">
                    Plateforme moderne de gestion des soutenances de fin d'études.<br>
                    Simplifiez l'organisation, la planification et le suivi des soutenances.
                </p>
                <div class="d-flex flex-wrap">
                    {% if not app.user %}
                        <a href="{{ path('app_login') }}" class="btn btn-login">
                            <i class="fas fa-sign-in-alt me-2"></i> Se connecter
                        </a>
                        <a href="#services" class="btn btn-outline-custom">
                            <i class="fas fa-info-circle me-2"></i> En savoir plus
                        </a>
                    {% else %}
                        <a href="{% if is_granted('ROLE_ADMIN') %}{{ path('admin_dashboard') }}{% else %}{{ path('enseignant_dashboard') }}{% endif %}" 
                           class="btn btn-dashboard">
                            <i class="fas fa-tachometer-alt me-2"></i> Accéder à mon espace
                        </a>
                    {% endif %}
                </div>
                <div class="mt-4">
                    <span class="stat-badge">
                        <i class="fas fa-check-circle me-1"></i> 50+ étudiants accompagnés
                    </span>
                </div>
            </div>
            <div class="col-lg-5 text-center mt-4 mt-lg-0">
                <img src="{{ asset('assets/images/hero-illustration.png') }}" alt="Illustration" class="hero-illustration img-fluid">
            </div>
        </div>
    </div>
</section>

<div class="container">
    <!-- Statistiques -->
    <div class="row mt-5 g-4">
        <div class="col-md-3 col-sm-6">
            <div class="stat-box">
                <div class="stat-number">50+</div>
                <div class="stat-label">Étudiants inscrits</div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="stat-box">
                <div class="stat-number">10+</div>
                <div class="stat-label">Enseignants</div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="stat-box">
                <div class="stat-number">98%</div>
                <div class="stat-label">Taux de satisfaction</div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="stat-box">
                <div class="stat-number">25+</div>
                <div class="stat-label">Soutenances organisées</div>
            </div>
        </div>
    </div>

    <!-- Section À propos -->
    <div class="about-section">
        <div class="row align-items-center">
            <div class="col-lg-6">
                <h2 class="section-title text-start" style="text-align: left !important;">À propos</h2>
                <h4 class="mb-3" style="color: #4680ff;">SoutenancePro</h4>
                <p>
                    Une plateforme dédiée à l'excellence académique pour la gestion des soutenances de fin d'études.
                </p>
                <p>
                    Notre mission est d'offrir une solution complète et intuitive qui répond aux besoins 
                    des établissements d'enseignement supérieur.
                </p>
                <div class="row mt-4">
                    <div class="col-6">
                        <div class="d-flex align-items-center mb-3">
                            <i class="fas fa-check-circle text-success me-2"></i>
                            <span>Gestion simplifiée</span>
                        </div>
                        <div class="d-flex align-items-center mb-3">
                            <i class="fas fa-check-circle text-success me-2"></i>
                            <span>Planification intelligente</span>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="d-flex align-items-center mb-3">
                            <i class="fas fa-check-circle text-success me-2"></i>
                            <span>Suivi en temps réel</span>
                        </div>
                        <div class="d-flex align-items-center mb-3">
                            <i class="fas fa-check-circle text-success me-2"></i>
                            <span>Rapports détaillés</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-6 text-center mt-4 mt-lg-0">
                <img src="{{ asset('assets/images/about-image.jpg') }}" alt="À propos" class="about-img">
            </div>
        </div>
    </div>

    <!-- Services / Fonctionnalités -->
    <div id="services">
        <h2 class="section-title">Nos services</h2>
    </div>
    <div class="row g-4 mb-5">
        <div class="col-md-3 col-sm-6">
            <div class="feature-card card">
                <img src="{{ asset('assets/images/student-icon.png') }}" class="feature-img" alt="Étudiants">
                <div class="card-body text-center">
                    <div class="feature-icon icon-primary mx-auto">
                        <i class="fas fa-users"></i>
                    </div>
                    <h5 class="card-title mt-2">Étudiants</h5>
                    <p class="card-text text-muted small">
                        Gestion complète des étudiants et de leurs mémoires.
                    </p>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="feature-card card">
                <img src="{{ asset('assets/images/teacher-icon.png') }}" class="feature-img" alt="Enseignants">
                <div class="card-body text-center">
                    <div class="feature-icon icon-success mx-auto">
                        <i class="fas fa-chalkboard-user"></i>
                    </div>
                    <h5 class="card-title mt-2">Enseignants</h5>
                    <p class="card-text text-muted small">
                        Gestion des enseignants et de leurs spécialités.
                    </p>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="feature-card card">
                <img src="{{ asset('assets/images/room-icon.png') }}" class="feature-img" alt="Salles">
                <div class="card-body text-center">
                    <div class="feature-icon icon-warning mx-auto">
                        <i class="fas fa-building"></i>
                    </div>
                    <h5 class="card-title mt-2">Salles</h5>
                    <p class="card-text text-muted small">
                        Gestion des salles et de leurs disponibilités.
                    </p>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="feature-card card">
                <img src="{{ asset('assets/images/defense-icon.png') }}" class="feature-img" alt="Soutenances">
                <div class="card-body text-center">
                    <div class="feature-icon icon-danger mx-auto">
                        <i class="fas fa-calendar-alt"></i>
                    </div>
                    <h5 class="card-title mt-2">Soutenances</h5>
                    <p class="card-text text-muted small">
                        Planification et suivi des soutenances.
                    </p>
                </div>
            </div>
        </div>
    </div>

    <!-- Témoignages -->
    <h2 class="section-title">Ce qu'ils disent de nous</h2>
    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="testimonial-card">
                <img src="{{ asset('assets/images/testimonial-1.jpg') }}" alt="Témoignage" class="testimonial-img" onerror="this.src='https://randomuser.me/api/portraits/men/1.jpg'">
                <i class="fas fa-quote-left fa-2x text-primary opacity-25 mb-2 d-block"></i>
                <p class="text-muted small">
                    "Une plateforme exceptionnelle qui a révolutionné la gestion des soutenances."
                </p>
                <div class="mt-3">
                    <strong>Dr. Jean Dupont</strong>
                    <div class="text-muted small">Directeur des études</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="testimonial-card">
                <img src="{{ asset('assets/images/testimonial-2.jpg') }}" alt="Témoignage" class="testimonial-img" onerror="this.src='https://randomuser.me/api/portraits/women/1.jpg'">
                <i class="fas fa-quote-left fa-2x text-primary opacity-25 mb-2 d-block"></i>
                <p class="text-muted small">
                    "Simple, intuitive et efficace. Je recommande vivement SoutenancePro."
                </p>
                <div class="mt-3">
                    <strong>Prof. Sophie Martin</strong>
                    <div class="text-muted small">Enseignante-chercheuse</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="testimonial-card">
                <img src="{{ asset('assets/images/testimonial-3.jpg') }}" alt="Témoignage" class="testimonial-img" onerror="this.src='https://randomuser.me/api/portraits/women/2.jpg'">
                <i class="fas fa-quote-left fa-2x text-primary opacity-25 mb-2 d-block"></i>
                <p class="text-muted small">
                    "Un gain de temps considérable dans l'organisation des soutenances."
                </p>
                <div class="mt-3">
                    <strong>Marie Petit</strong>
                    <div class="text-muted small">Responsable pédagogique</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Call to Action -->
    <div class="cta-section">
        <h3 class="mb-3">Prêt à simplifier la gestion de vos soutenances ?</h3>
        <p class="mb-4">Rejoignez les nombreux établissements qui nous font confiance</p>
        {% if not app.user %}
            <a href="{{ path('app_login') }}" class="btn btn-light">
                <i class="fas fa-sign-in-alt me-2"></i> Commencer maintenant
            </a>
        {% else %}
            <a href="{% if is_granted('ROLE_ADMIN') %}{{ path('admin_dashboard') }}{% else %}{{ path('enseignant_dashboard') }}{% endif %}" 
               class="btn btn-light">
                <i class="fas fa-tachometer-alt me-2"></i> Accéder à mon espace
            </a>
        {% endif %}
    </div>
</div>

<!-- Footer -->
<footer>
    <div class="container">
        <div class="row">
            <div class="col-md-4">
                <h5>SoutenancePro</h5>
                <p class="text-muted small">
                    Plateforme moderne de gestion des soutenances de fin d'études.
                </p>
                <div class="social-icons mt-3">
                    <a href="#"><i class="fab fa-facebook-f"></i></a>
                    <a href="#"><i class="fab fa-twitter"></i></a>
                    <a href="#"><i class="fab fa-linkedin-in"></i></a>
                    <a href="#"><i class="fab fa-instagram"></i></a>
                </div>
            </div>
            <div class="col-md-4">
                <h5>Liens rapides</h5>
                <ul class="list-unstyled">
                    <li><a href="#"><i class="fas fa-chevron-right me-2"></i> À propos</a></li>
                    <li><a href="#"><i class="fas fa-chevron-right me-2"></i> Contact</a></li>
                    <li><a href="#"><i class="fas fa-chevron-right me-2"></i> Mentions légales</a></li>
                    <li><a href="#"><i class="fas fa-chevron-right me-2"></i> FAQ</a></li>
                </ul>
            </div>
            <div class="col-md-4">
                <h5>Contact</h5>
                <p class="text-muted small mb-2">
                    <i class="fas fa-envelope me-2"></i> contact@soutenancepro.com
                </p>
                <p class="text-muted small mb-2">
                    <i class="fas fa-phone me-2"></i> +221 33 123 45 67
                </p>
                <p class="text-muted small">
                    <i class="fas fa-map-marker-alt me-2"></i> Dakar, Sénégal
                </p>
            </div>
        </div>
        <div class="row mt-4">
            <div class="col-12 text-center">
                <hr class="bg-secondary opacity-25">
                <p class="text-muted small mb-0">
                    &copy; {{ "now"|date("Y") }} SoutenancePro - Tous droits réservés
                </p>
            </div>
        </div>
    </div>
</footer>
{% endblock %}