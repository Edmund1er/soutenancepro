{% extends 'admin_layout.html.twig' %}

{% block title %}Mes jurys{% endblock %}

{% block body %}
<!-- [ breadcrumb ] start -->
<div class="page-header">
    <div class="page-block">
        <div class="row align-items-center">
            <div class="col-md-12">
                <div class="page-header-title">
                    <h5 class="m-b-10">Composition de mes jurys</h5>
                </div>
                <ul class="breadcrumb">
                    <li class="breadcrumb-item"><a href="{{ path('enseignant_dashboard') }}"><i class="feather icon-home"></i></a></li>
                    <li class="breadcrumb-item"><a href="#!">Mes jurys</a></li>
                </ul>
            </div>
        </div>
    </div>
</div>
<!-- [ breadcrumb ] end -->

<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header">
                <h5>Composition des jurys où je participe</h5>
                <div class="card-header-right">
                    <div class="btn-group card-option">
                        <button type="button" class="btn dropdown-toggle" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                            <i class="feather icon-more-horizontal"></i>
                        </button>
                        <ul class="list-unstyled card-option dropdown-menu dropdown-menu-right">
                            <li class="dropdown-item full-card"><a href="#!"><span><i class="feather icon-maximize"></i> maximize</span><span style="display:none"><i class="feather icon-minimize"></i> Restore</span></a></li>
                            <li class="dropdown-item minimize-card"><a href="#!"><span><i class="feather icon-minus"></i> collapse</span><span style="display:none"><i class="feather icon-plus"></i> expand</span></a></li>
                            <li class="dropdown-item reload-card"><a href="#!"><i class="feather icon-refresh-cw"></i> reload</a></li>
                            <li class="dropdown-item close-card"><a href="#!"><i class="feather icon-trash"></i> remove</a></li>
                        </ul>
                    </div>
                </div>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover table-bordered">
                        <thead class="thead-light">
                            <tr>
                                <th>ETUDIANT</th>
                                <th>THEME</th>
                                <th>DATE</th>
                                <th>HEURE</th>
                                <th>SALLE</th>
                                <th>PRESIDENT</th>
                                <th>RAPPORTEUR</th>
                                <th>EXAMINATEUR</th>
                            </tr>
                        </thead>
                        <tbody>
                        {% for soutenance in soutenances %}
                            <tr>
                                <td><strong>{{ soutenance.etudiant.nom }} {{ soutenance.etudiant.prenom }}</strong></td>
                                <td>{{ soutenance.etudiant.themeMemoire|slice(0, 40) }}{% if soutenance.etudiant.themeMemoire|length > 40 %}...{% endif %}</td>
                                <td>{{ soutenance.date|date('d/m/Y') }}</td>
                                <td>{{ soutenance.heure|date('H:i') }}</td>
                                <td>{{ soutenance.salle.code }}<br><small class="text-muted">{{ soutenance.salle.localisation }}</small></td>
                                <td>
                                    {% if soutenance.president %}
                                        {{ soutenance.president.nom }} {{ soutenance.president.prenom }}
                                        {% if soutenance.president.id == app.user.id %}
                                            <span class="badge badge-danger">(Moi)</span>
                                        {% endif %}
                                    {% else %}
                                        <span class="text-muted">Non defini</span>
                                    {% endif %}
                                </td>
                                <td>
                                    {% if soutenance.rapporteur %}
                                        {{ soutenance.rapporteur.nom }} {{ soutenance.rapporteur.prenom }}
                                        {% if soutenance.rapporteur.id == app.user.id %}
                                            <span class="badge badge-warning">(Moi)</span>
                                        {% endif %}
                                    {% else %}
                                        <span class="text-muted">Non defini</span>
                                    {% endif %}
                                </td>
                                <td>
                                    {% if soutenance.examinateur %}
                                        {{ soutenance.examinateur.nom }} {{ soutenance.examinateur.prenom }}
                                        {% if soutenance.examinateur.id == app.user.id %}
                                            <span class="badge badge-info">(Moi)</span>
                                        {% endif %}
                                    {% else %}
                                        <span class="text-muted">Non defini</span>
                                    {% endif %}
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="8" class="text-center text-muted py-4">
                                    Aucun jury pour le moment
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>

                <!-- PAGINATION (5 lignes max) -->
                {% if totalPages > 1 %}
                <div class="row mt-3">
                    <div class="col-sm-12">
                        <nav aria-label="Page navigation">
                            <ul class="pagination justify-content-center">
                                {% if page > 1 %}
                                    <li class="page-item"><a class="page-link" href="{{ path('enseignant_mes_jurys', {page: page-1}) }}">Precedent</a></li>
                                {% else %}
                                    <li class="page-item disabled"><span class="page-link">Precedent</span></li>
                                {% endif %}

                                {% for p in 1..totalPages %}
                                    <li class="page-item {{ p == page ? 'active' : '' }}">
                                        <a class="page-link" href="{{ path('enseignant_mes_jurys', {page: p}) }}">{{ p }}</a>
                                    </li>
                                {% endfor %}

                                {% if page < totalPages %}
                                    <li class="page-item"><a class="page-link" href="{{ path('enseignant_mes_jurys', {page: page+1}) }}">Suivant</a></li>
                                {% else %}
                                    <li class="page-item disabled"><span class="page-link">Suivant</span></li>
                                {% endif %}
                            </ul>
                        </nav>
                    </div>
                </div>
                {% endif %}
                
                <!-- Affichage du nombre de resultats -->
                {% if totalPages > 0 %}
                <div class="row mt-2">
                    <div class="col-sm-12 text-center">
                        <small class="text-muted">
                            Page {{ page }} sur {{ totalPages }} - Total: {{ soutenances|length }} jury(s) affiche(s)
                        </small>
                    </div>
                </div>
                {% endif %}
            </div>
            <div class="card-footer text-right">
                <a href="{{ path('enseignant_dashboard') }}" class="text-primary">
                    <i class="feather icon-arrow-left"></i> Retour au dashboard
                </a>
            </div>
        </div>
    </div>
</div>
{% endblock %}